{
  "name": "md-render",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "check-env": "node render.js --check-env",
    "test": "node test-smoke.js",
    "smoke": "node test-smoke.js",
    "smoke:html": "node render.js --in sample.md --out /tmp/md-render-smoke.html --standalone --safe",
    "smoke:png": "node render.js --in sample.md --out /tmp/md-render-smoke.png --theme github --safe"
  },
  "dependencies": {
    "@twemoji/svg": "^15.0.0",
    "@vscode/markdown-it-katex": "^1.1.2",
    "katex": "^0.16.11",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mathjax-full": "^3.2.1",
    "mermaid": "^10.9.0",
    "puppeteer-core": "^24.43.0",
    "shiki": "^4.0.2",
    "twemoji": "^14.0.2"
  }
}
